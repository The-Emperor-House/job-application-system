PORT=4000
NODE_ENV=development

# MySQL connection string (matches the docker-compose MySQL service)
DATABASE_URL="mysql://root:root@127.0.0.1:3307/job_application_system"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="8h"

# CORS - URL of the web app
CORS_ORIGIN="http://localhost:3000"

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email OTP verification (optional - if SMTP_HOST is unset, OTP codes are logged to the console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@job-application-system.local
OTP_EXPIRES_MINUTES=10

# Google sign-in (used to verify ID tokens sent from the web app)
GOOGLE_CLIENT_ID=
